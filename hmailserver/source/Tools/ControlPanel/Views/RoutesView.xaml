<UserControl
    x:Class="hMailServer.ControlPanel.Views.RoutesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Routes" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Deliver mail for specific domains through a designated SMTP host instead of MX lookup."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <DataGrid x:Name="RouteGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      Background="Transparent" BorderThickness="0" RowHeight="34"
                      SelectionMode="Single" MouseDoubleClick="Edit_Click">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Domain" Binding="{Binding DomainName}" Width="*" />
                    <DataGridTextColumn Header="Target host" Binding="{Binding TargetHost}" Width="*" />
                    <DataGridTextColumn Header="Port" Binding="{Binding TargetPort}" Width="80" />
                    <DataGridTextColumn Header="Retries" Binding="{Binding Retries}" Width="80" />
                    <DataGridTextColumn Header="Auth" Binding="{Binding Auth}" Width="80" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Add route" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="NewDomain" PlaceholderText="Domain (e.g. partner.com)" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewHost" Grid.Column="1" PlaceholderText="Target SMTP host" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewPort" Grid.Column="2" PlaceholderText="Port" Text="25" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="3" Content="Add" Appearance="Primary" Click="Add_Click" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="4" Content="Properties" Click="Edit_Click" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="5" Content="Delete selected" Appearance="Danger" Click="Delete_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
