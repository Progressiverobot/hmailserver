<UserControl
    x:Class="hMailServer.ControlPanel.Views.QueueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid>
            <StackPanel>
                <TextBlock Text="Delivery queue" Style="{StaticResource PageTitle}" />
                <TextBlock x:Name="SubtitleText" Text="Messages waiting for delivery."
                           Style="{StaticResource PageSubtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <ui:Button Content="View source" Click="View_Click" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="DocumentText24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Deliver now" Appearance="Primary" Click="Retry_Click" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Send24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Remove" Appearance="Danger" Click="Remove_Click" Margin="0,0,8,0">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="Delete24" /></ui:Button.Icon>
                </ui:Button>
                <ui:Button Content="Refresh" Click="Refresh_Click">
                    <ui:Button.Icon><ui:SymbolIcon Symbol="ArrowClockwise24" /></ui:Button.Icon>
                </ui:Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <DataGrid x:Name="QueueGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      Background="Transparent" BorderThickness="0" RowHeight="34"
                      MouseDoubleClick="View_Click">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="90" />
                    <DataGridTextColumn Header="Created" Binding="{Binding Created}" Width="150" />
                    <DataGridTextColumn Header="From" Binding="{Binding From}" Width="*" />
                    <DataGridTextColumn Header="Recipients" Binding="{Binding Recipients}" Width="*" />
                    <DataGridTextColumn Header="Next try" Binding="{Binding NextTry}" Width="150" />
                    <DataGridTextColumn Header="Tries" Binding="{Binding Tries}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
