<UserControl
    x:Class="hMailServer.ControlPanel.Views.IPRangesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="IP ranges" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Access control: which addresses may connect and what they are allowed to do. Higher priority wins."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <DataGrid x:Name="RangeGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      Background="Transparent" BorderThickness="0" RowHeight="34"
                      SelectionMode="Single" SelectionChanged="RangeGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Lower IP" Binding="{Binding LowerIP}" Width="150" />
                    <DataGridTextColumn Header="Upper IP" Binding="{Binding UpperIP}" Width="150" />
                    <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" Width="80" />
                    <DataGridTextColumn Header="SMTP" Binding="{Binding Smtp}" Width="70" />
                    <DataGridTextColumn Header="IMAP" Binding="{Binding Imap}" Width="70" />
                    <DataGridTextColumn Header="POP3" Binding="{Binding Pop3}" Width="70" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock x:Name="PermHeader" Text="Permissions (select a range)" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                <UniformGrid Columns="4" Margin="0,0,0,12">
                    <CheckBox x:Name="PermSmtp" Content="Allow SMTP" FontSize="13" Margin="0,0,12,8" />
                    <CheckBox x:Name="PermImap" Content="Allow IMAP" FontSize="13" Margin="0,0,12,8" />
                    <CheckBox x:Name="PermPop3" Content="Allow POP3" FontSize="13" Margin="0,0,12,8" />
                    <CheckBox x:Name="PermTlsAuth" Content="Require TLS for auth" FontSize="13" Margin="0,0,12,8" />
                    <CheckBox x:Name="PermLL" Content="Deliver local → local" FontSize="13" Margin="0,0,12,0" />
                    <CheckBox x:Name="PermLR" Content="Deliver local → remote" FontSize="13" Margin="0,0,12,0" />
                    <CheckBox x:Name="PermRL" Content="Deliver remote → local" FontSize="13" Margin="0,0,12,0" />
                    <CheckBox x:Name="PermRR" Content="Deliver remote → remote (relay)" FontSize="13" Margin="0,0,12,0" />
                </UniformGrid>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="SavePermsButton" Content="Save permissions" Appearance="Primary" Click="SavePerms_Click" IsEnabled="False" Margin="0,0,8,0" />
                    <ui:Button Content="Delete selected range" Appearance="Danger" Click="Delete_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Add range" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="NewName" PlaceholderText="Name" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewLower" Grid.Column="1" PlaceholderText="Lower IP (e.g. 10.0.0.0)" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewUpper" Grid.Column="2" PlaceholderText="Upper IP (e.g. 10.0.0.255)" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewPriority" Grid.Column="3" PlaceholderText="Priority" Text="15" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="4" Content="Add" Appearance="Primary" Click="Add_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
