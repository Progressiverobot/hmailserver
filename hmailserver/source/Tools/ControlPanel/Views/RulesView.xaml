<UserControl
    x:Class="hMailServer.ControlPanel.Views.RulesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Global rules" Style="{StaticResource PageTitle}" />
            <TextBlock x:Name="SubtitleText"
                       Text="Server-wide message rules, evaluated top to bottom."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <DataGrid x:Name="RuleGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="None"
                          Background="Transparent" BorderThickness="0" RowHeight="34"
                          SelectionMode="Single" SelectionChanged="RuleGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Binding="{Binding Position}" Width="50" />
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="Enabled" Binding="{Binding Enabled}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
                <Border Grid.Row="1" BorderThickness="0,1,0,0" Padding="12,10"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                    <StackPanel>
                        <TextBlock Text="RULE DETAILS" FontSize="10" Margin="0,0,0,6"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="DetailText" Text="Select a rule to see its criteria and actions."
                                   FontSize="12.5" TextWrapping="Wrap"
                                   FontFamily="Cascadia Mono, Consolas" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <ui:Button Content="Move up" Click="MoveUp_Click" Margin="0,0,8,0" />
                <ui:Button Content="Move down" Click="MoveDown_Click" Margin="0,0,8,0" />
                <ui:Button Content="Enable / disable" Click="Toggle_Click" Margin="0,0,8,0" />
                <ui:Button Content="Delete rule" Appearance="Danger" Click="Delete_Click" Margin="0,0,24,0" />
                <ui:TextBox x:Name="NewRuleName" PlaceholderText="New rule name" AutomationProperties.Name="New rule name" Width="200" Margin="0,0,8,0" />
                <ui:Button Content="Add rule" Appearance="Primary" Click="AddRule_Click" />
            </StackPanel>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Edit selected rule" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="IF" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox x:Name="CritField" Grid.Column="1" Margin="0,0,8,0" SelectedIndex="0" />
                        <ComboBox x:Name="CritMatch" Grid.Column="2" Margin="0,0,8,0" SelectedIndex="1" />
                        <ui:TextBox x:Name="CritValue" Grid.Column="3" PlaceholderText="Value" AutomationProperties.Name="Criterion value" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="4" Content="Add criterion" Click="AddCriterion_Click" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="5" Content="Remove last" Click="RemoveCriterion_Click" />
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="THEN" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <ComboBox x:Name="ActionType" Grid.Column="1" Margin="0,0,8,0" SelectedIndex="0" />
                        <ui:TextBox x:Name="ActionParam" Grid.Column="2" PlaceholderText="Parameter (address, folder, Header=Value...)" AutomationProperties.Name="Action parameter" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="3" Content="Add action" Click="AddAction_Click" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="4" Content="Remove last" Click="RemoveAction_Click" />
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
