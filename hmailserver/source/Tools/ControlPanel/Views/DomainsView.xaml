<UserControl
    x:Class="hMailServer.ControlPanel.Views.DomainsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Domains &amp; accounts" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Manage the domains hosted by this server and their mailboxes."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Domain list -->
            <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListView x:Name="DomainList" SelectionChanged="DomainList_SelectionChanged"
                              BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,6">
                                    <ui:SymbolIcon Symbol="Globe24" Foreground="{StaticResource BrandBrush}" />
                                    <TextBlock Text="{Binding}" Margin="10,0,0,0" FontSize="14" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,10,0,2">
                        <ui:TextBox x:Name="NewDomainBox" PlaceholderText="newdomain.com" Width="180" />
                        <ui:Button Content="Add domain" Margin="8,0,0,0" Click="AddDomain_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Accounts for the selected domain -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="AccountsHeader" Text="Select a domain" FontWeight="SemiBold"
                               FontSize="14" Margin="6,4,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <ListView x:Name="AccountList" Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Person24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding}" Margin="10,0,0,0" FontSize="13.5" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="Delete" Appearance="Danger" FontSize="11"
                                               Padding="8,3" Tag="{Binding}" Click="DeleteAccount_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2" Margin="4,10,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="NewAccountBox" PlaceholderText="user@domain" Margin="0,0,8,0" />
                        <ui:PasswordBox x:Name="NewAccountPassword" Grid.Column="1" PlaceholderText="Password" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="2" Content="Create account" Appearance="Primary" Click="AddAccount_Click" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
