<UserControl
    x:Class="hMailServer.ControlPanel.Views.DomainsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Domains &amp; accounts" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Manage the domains hosted by this server and their mailboxes."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <!-- Domain list -->
            <Border Style="{StaticResource Card}" Margin="0,0,12,0" Padding="10" Grid.RowSpan="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListView x:Name="DomainList" SelectionChanged="DomainList_SelectionChanged"
                              BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Globe24" Foreground="{StaticResource BrandBrush}" />
                                        <TextBlock Text="{Binding}" Margin="10,0,0,0" FontSize="14" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="Properties" FontSize="11" Padding="8,3"
                                               Tag="{Binding}" Click="EditDomain_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,10,0,2">
                        <ui:TextBox x:Name="NewDomainBox" PlaceholderText="newdomain.com" Width="180" />
                        <ui:Button Content="Add domain" Margin="8,0,0,0" Click="AddDomain_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Accounts for the selected domain -->
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="AccountsHeader" Text="Select a domain" FontWeight="SemiBold"
                               FontSize="14" Margin="6,4,0,8"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

                    <ListView x:Name="AccountList" Grid.Row="1" BorderThickness="0" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Person24" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding}" Margin="10,0,0,0" FontSize="13.5" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <ui:Button Grid.Column="1" Content="Edit" FontSize="11" Padding="8,3" Margin="0,0,6,0"
                                               Tag="{Binding}" Click="EditAccount_Click" />
                                    <ui:Button Grid.Column="2" Content="Delete" Appearance="Danger" FontSize="11"
                                               Padding="8,3" Tag="{Binding}" Click="DeleteAccount_Click" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Grid Grid.Row="2" Margin="4,10,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox x:Name="NewAccountBox" PlaceholderText="user@domain" Margin="0,0,8,0" />
                        <ui:PasswordBox x:Name="NewAccountPassword" Grid.Column="1" PlaceholderText="Password" Margin="0,0,8,0" />
                        <ui:Button Grid.Column="2" Content="Create account" Appearance="Primary" Click="AddAccount_Click" />
                    </Grid>
                </Grid>
            </Border>

            <!-- Aliases + distribution lists -->
            <Grid Grid.Column="1" Grid.Row="1" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}" Padding="10" Margin="0,0,12,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Aliases" FontWeight="SemiBold" FontSize="13.5" Margin="6,2,0,6" />
                        <ListView x:Name="AliasList" Grid.Row="1" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Display}" FontSize="12.5" VerticalAlignment="Center" />
                                        <ui:Button Grid.Column="1" Content="✕" FontSize="10" Padding="6,2"
                                                   Tag="{Binding Name}" Click="DeleteAlias_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid Grid.Row="2" Margin="4,8,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="NewAliasName" PlaceholderText="alias@domain" FontSize="12" Margin="0,0,6,0" />
                            <ui:TextBox x:Name="NewAliasValue" Grid.Column="1" PlaceholderText="target@anywhere" FontSize="12" Margin="0,0,6,0" />
                            <ui:Button Grid.Column="2" Content="Add" FontSize="12" Click="AddAlias_Click" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Distribution lists" FontWeight="SemiBold" FontSize="13.5" Margin="6,2,0,6" />
                        <ListView x:Name="DistList" Grid.Row="1" BorderThickness="0" Background="Transparent">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="4,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding}" FontSize="12.5" VerticalAlignment="Center" />
                                        <ui:Button Grid.Column="1" Content="Properties" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                                   Tag="{Binding}" Click="EditDistList_Click" />
                                        <ui:Button Grid.Column="2" Content="Members" FontSize="10" Padding="6,2" Margin="0,0,4,0"
                                                   Tag="{Binding}" Click="EditRecipients_Click" />
                                        <ui:Button Grid.Column="3" Content="✕" FontSize="10" Padding="6,2"
                                                   Tag="{Binding}" Click="DeleteDistList_Click" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <Grid Grid.Row="2" Margin="4,8,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="NewDistAddress" PlaceholderText="list@domain" FontSize="12" Margin="0,0,6,0" />
                            <ui:Button Grid.Column="1" Content="Add" FontSize="12" Click="AddDistList_Click" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
