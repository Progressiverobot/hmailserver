<UserControl
    x:Class="hMailServer.ControlPanel.Views.SslCertificatesView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid Margin="26,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="SSL certificates" Style="{StaticResource PageTitle}" />
            <TextBlock Text="Certificates available for TLS ports. With ACME enabled, Let's Encrypt certificates appear here automatically."
                       Style="{StaticResource PageSubtitle}" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
            <DataGrid x:Name="CertGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="None"
                      Background="Transparent" BorderThickness="0" RowHeight="34"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                    <DataGridTextColumn Header="Certificate file" Binding="{Binding CertificateFile}" Width="*" />
                    <DataGridTextColumn Header="Private key file" Binding="{Binding PrivateKeyFile}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Add certificate" FontSize="15" FontWeight="SemiBold" Margin="0,0,0,12" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="NewCertName" PlaceholderText="Name" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewCertFile" Grid.Column="1" PlaceholderText="Certificate file (PEM)" Margin="0,0,4,0" />
                    <ui:Button Grid.Column="2" Content="..." Click="BrowseCert_Click" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="NewKeyFile" Grid.Column="3" PlaceholderText="Private key file (PEM)" Margin="0,0,4,0" />
                    <ui:Button Grid.Column="4" Content="..." Click="BrowseKey_Click" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="5" Content="Add" Appearance="Primary" Click="Add_Click" Margin="0,0,8,0" />
                    <ui:Button Grid.Column="6" Content="Delete selected" Appearance="Danger" Click="Delete_Click" />
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
