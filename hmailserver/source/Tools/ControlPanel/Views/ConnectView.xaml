<UserControl
    x:Class="hMailServer.ControlPanel.Views.ConnectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Border Style="{StaticResource Card}" Width="400" Padding="34"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel>
                <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource BrandGradient}"
                        HorizontalAlignment="Left" Margin="0,0,0,16">
                    <TextBlock Text="hM" FontWeight="Bold" FontSize="20" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <TextBlock Text="Connect to server" FontSize="22" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="Sign in with the hMailServer administrator credential."
                           FontSize="12.5" Margin="0,4,0,22"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <ui:TextBox x:Name="HostBox" PlaceholderText="Server (localhost)" Margin="0,0,0,10" Text="localhost">
                    <ui:TextBox.Icon><ui:SymbolIcon Symbol="Server24" /></ui:TextBox.Icon>
                </ui:TextBox>
                <ui:TextBox x:Name="UserBox" PlaceholderText="User name" Margin="0,0,0,10" Text="Administrator">
                    <ui:TextBox.Icon><ui:SymbolIcon Symbol="Person24" /></ui:TextBox.Icon>
                </ui:TextBox>
                <ui:PasswordBox x:Name="PasswordBox" PlaceholderText="Password" Margin="0,0,0,18">
                    <ui:PasswordBox.Icon><ui:SymbolIcon Symbol="Key24" /></ui:PasswordBox.Icon>
                </ui:PasswordBox>

                <ui:Button x:Name="ConnectButton" Content="Connect" Appearance="Primary"
                           HorizontalAlignment="Stretch" Height="38" Click="Connect_Click" />

                <TextBlock x:Name="ErrorText" Foreground="#F85149" FontSize="12" Margin="0,12,0,0"
                           TextWrapping="Wrap" Visibility="Collapsed" />

                <ui:HyperlinkButton Content="Set up two-factor authentication…" Click="Totp_Click"
                                    HorizontalAlignment="Left" Margin="0,12,0,0" FontSize="12" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
