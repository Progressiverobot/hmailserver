<ui:FluentWindow
    x:Class="hMailServer.ControlPanel.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="hMailServer Control Panel"
    Width="1280" Height="800"
    MinWidth="980" MinHeight="640"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="hMailServer Control Panel" ShowMaximize="True" ShowMinimize="True">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Mail24" Foreground="{StaticResource BrandBrush}" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Brand -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="18,10,0,12">
                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource BrandGradient}">
                        <TextBlock Text="hM" FontWeight="Bold" FontSize="14" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="hMailServer" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="CONTROL PANEL" FontSize="9" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Navigation tree (structure mirrors the classic Administrator) -->
                <TreeView x:Name="NavTree" Grid.Row="1" Background="Transparent" BorderThickness="0"
                          Margin="8,0" SelectedItemChanged="NavTree_SelectedItemChanged"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="Padding" Value="4,5" />
                            <Setter Property="Margin" Value="0,1" />
                            <Setter Property="FontSize" Value="13" />
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Margin="18,0,18,14">
                    <StackPanel x:Name="ConnBadge" Orientation="Horizontal" Visibility="Collapsed">
                        <Ellipse Width="8" Height="8" Fill="#3FB950" VerticalAlignment="Center" />
                        <TextBlock x:Name="ConnText" Margin="7,0,0,0" FontSize="11.5"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Grid Margin="0,6,0,0">
                        <TextBlock x:Name="VersionText" FontSize="10.5" Margin="15,4,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <ui:Button x:Name="ThemeButton" Content="◐" FontSize="13" Padding="7,3"
                                   HorizontalAlignment="Right" ToolTip="Toggle light/dark theme"
                                   Click="Theme_Click" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Content -->
            <Border Grid.Column="1" Background="{DynamicResource ApplicationBackgroundBrush}"
                    CornerRadius="8,0,0,0" Margin="0,4,0,0">
                <ContentControl x:Name="ContentHost" />
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
